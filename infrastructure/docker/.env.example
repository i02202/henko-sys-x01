# Henko Sys x01 — Docker Compose env vars
# Copy this file to .env in the same directory and fill in real values:
#   cp .env.example .env
# .env is gitignored — never commit real secrets.

# n8n encryption key (used to encrypt credentials stored in n8n DB)
# Generate one: openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace-me-with-openssl-rand-hex-32

# n8n Postgres password (used by both n8n and the embedded postgres container)
# Generate one: openssl rand -hex 16
N8N_DB_PASSWORD=replace-me-with-strong-random-password
